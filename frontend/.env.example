# Leave empty for same-origin requests (local dev uses the Vite proxy to :8000).
# In production, set to your deployed backend origin, e.g. https://doxa-api.vercel.app
VITE_API_BASE_URL=

# Console + UI API Inspector. On by default in `npm run dev`; set true to enable in production builds.
VITE_ENABLE_API_DEBUG=false
