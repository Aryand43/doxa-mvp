# Copy this file to .env and fill in your values
# cp .env.example .env
#
# NOTE: The MVP runs fully offline with NO configuration. Everything below is
# OPTIONAL and only enables enhancements (LLM phrasing, IRIS vector search).

# ── Retrieval backend ───────────────────────────────────────────
# "local"  -> in-process TF-IDF vector store (default, no deps, offline)
# "iris"   -> use InterSystems IRIS vector search (falls back to local on error)
RETRIEVAL_BACKEND=local

# ── Optional LLM (plain-language phrasing only) ─────────────────
# Without a key, answers/reports/alerts are still computed deterministically.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Optional: IRIS vector seam (only if RETRIEVAL_BACKEND=iris) ──
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
IRIS_HOST=localhost
IRIS_PORT=1972
IRIS_NAMESPACE=USER
IRIS_USERNAME=
IRIS_PASSWORD=
IRIS_VECTOR_TABLE=SQLUser.ProcurementVectors
