# Copy this file to .env and fill in your values
# cp .env.example .env
#
# NOTE: The MVP runs fully offline with NO configuration. Everything below is
# OPTIONAL and only enables enhancements (LLM phrasing, IRIS vector search).

# ── Authentication / RBAC / tenant isolation ───────────────────────────────
# Local MVP default keeps the app usable without a platform token. Set true in
# UAT/prod so every /api/ai request must include Authorization: Bearer <JWT>.
AUTH_REQUIRED=false

# MVP validator supports HMAC-signed JWTs. Claims expected by the backend:
#   sub/user_uuid, companies[] or buyer_company_uuid, authorities[], roles[]
AUTH_JWT_SECRET=
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=
AUTH_DEV_LOGIN_ENABLED=true
AUTH_TOKEN_TTL_SECONDS=7200

# ── Retrieval backend ───────────────────────────────────────────
# "local"  -> in-process TF-IDF vector store (default, no deps, offline)
# "iris"   -> use InterSystems IRIS vector search (falls back to local on error)
RETRIEVAL_BACKEND=local

# ── Optional LLM (plain-language phrasing only) ─────────────────
# Without a key, answers/reports/alerts are still computed deterministically.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Optional: IRIS vector seam (only if RETRIEVAL_BACKEND=iris) ──
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
IRIS_HOST=localhost
IRIS_PORT=1972
IRIS_NAMESPACE=USER
IRIS_USERNAME=
IRIS_PASSWORD=
IRIS_VECTOR_TABLE=SQLUser.ProcurementVectors
