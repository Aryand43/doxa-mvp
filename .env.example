# Copy this file to .env and fill in your values
# cp .env.example .env

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Embeddings (IRIS vector POC 1) ──────────────────────────────
# EMBEDDING_DIM must match the VECTOR(FLOAT, n) length of the IRIS table.
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ── InterSystems IRIS (vector DB, POC 1) ────────────────────────
IRIS_HOST=localhost
IRIS_PORT=1972
IRIS_NAMESPACE=USER
IRIS_USERNAME=
IRIS_PASSWORD=
IRIS_VECTOR_TABLE=SQLUser.ProcurementVectors
